# Merlin Configuration
# Copy this to .env and fill in your values

# Camera credentials (required)
MERLIN_CAMERA_PASS=your_camera_password_here
MERLIN_CAMERA_IP=192.168.1.26
MERLIN_CAMERA_USER=admin

# Network (Tailscale IPs or LAN IPs)
MERLIN_PI_HOST=100.87.156.70

# Ollama chat model (see `ollama list`; start-merlin-ollama.sh defaults to qwen3-vl:2b)
MERLIN_MODEL=qwen3-vl:2b
# Ollama: keep chain-of-thought out of speech (default). Set to low|medium|high to allow more reasoning in replies.
# MERLIN_LLM_REASONING_EFFORT=none

# TTS voice (optional)
MERLIN_VOICE=am_fenrir

# USB Merlin camera (optional). If unset on macOS + MERLIN_AUDIO_SOURCE=usb, PIXY is auto-detected
# from ffmpeg's *video* device list. Set explicitly if the wrong camera opens, e.g. MERLIN_CAMERA_INDEX=2
# MERLIN_CAMERA_INDEX=0

# Vision / scene model (Ollama: often same VLM as MERLIN_MODEL, e.g. qwen3-vl:2b)
MERLIN_VISION_MODEL=qwen3-vl:2b

# ElevenLabs (only needed for generate_sounds.py, not core operation)
# ELEVENLABS_API_KEY=your_key_here
